import uuid
from datetime import datetime

class Patient:
    """Manages the computational state and historical clinical data of an individual patient."""
    def __init__(self, name: str, age: int, medical_id: str = None):
        self.patient_id = medical_id if medical_id else str(uuid.uuid4())[:8].upper()
        self.name = name
        self.age = age
        self.admission_status = "Discharged"
        self.assigned_ward = "None"
        self.vitals_history = []
        self.diagnoses = []

    def log_vitals(self, systolic_bp: int, diastolic_bp: int, heart_rate: int, oxygen_sat: float):
        """Records a timestamped snapshot of core physiological parameters."""
        entry = {
            "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            "bp": (systolic_bp, diastolic_bp),
            "hr": heart_rate,
            "spo2": oxygen_sat
        }
        self.vitals_history.append(entry)
        return entry


class PatientManagementSystem:
    """Central architectural engine handling registry operations, alerting, and data summaries."""
    def __init__(self):
        self.patient_registry = {}

    def register_patient(self, name: str, age: int) -> Patient:
        """Creates a new patient profile and persists it to the active registry memory."""
        new_patient = Patient(name, age)
        self.patient_registry[new_patient.patient_id] = new_patient
        return new_patient

    def update_admission(self, patient_id: str, status: str, ward: str):
        """Changes admission states across clinical departments."""
        if patient_id in self.patient_registry:
            pt = self.patient_registry[patient_id]
            pt.admission_status = status
            pt.assigned_ward = ward
            return True
        return False

    def evaluate_clinical_risks(self, patient_id: str) -> list:
        """
        Runs an anomaly detection algorithm over the latest vitals matrix.
        Returns a list of active safety alarms based on clinical boundaries.
        """
        alarms = []
        if patient_id not in self.patient_registry:
            return ["Error: Patient ID non-existent"]
            
        pt = self.patient_registry[patient_id]
        if not pt.vitals_history:
            return ["No vitals logged yet"]

        latest = pt.vitals_history[-1]
        sbp, dbp = latest["bp"]
        hr = latest["hr"]
        spo2 = latest["spo2"]

        # 1. Oxygen Saturation Flag (Critical threshold for respiratory failure)
        if spo2 < 92.0:
            alarms.append(f"CRITICAL: Hypoxia Detected (SpO2: {spo2}%)")
            
        # 2. Hemodynamic Stability Check (Blood Pressure)
        if sbp > 160 or dbp > 100:
            alarms.append(f"WARNING: Severe Hypertension Matrix ({sbp}/{dbp} mmHg)")
        elif sbp < 90:
            alarms.append(f"CRITICAL: Hypotension / Shock State ({sbp}/{dbp} mmHg)")
            
        # 3. Cardiac Rate Metric Boundary
        if hr > 110:
            alarms.append(f"WARNING: Tachycardia Event Registrate ({hr} bpm)")
        elif hr < 50:
            alarms.append(f"WARNING: Bradycardia Event Registrate ({hr} bpm)")

        return alarms if alarms else ["Patient Stable - No Flags Triggered"]


# =====================================================================
# SYSTEM VERIFICATION AND OPERATIONAL SIMULATION
# =====================================================================
if __name__ == "__main__":
    # 1. Initialize the system engine
    epms = PatientManagementSystem()
    
    # 2. Simulate registering a patient
    patient_joe = epms.register_patient(name="Joseph Tarawallie", age=45)
    print(f"System Action: Registered Patient {patient_joe.name} [ID: {patient_joe.patient_id}]")
    
    # 3. Simulate Clinical Admission Change
    epms.update_admission(patient_id=patient_joe.patient_id, status="Admitted", ward="ICU Pod B")
    print(f"System Action: Ward Status Updated -> Status: {patient_joe.admission_status} | Ward: {patient_joe.assigned_ward}\n")
    
    # 4. Scenario A: Logging baseline normal physiological markers
    print("--- SIMULATION 1: NORMAL STATE OVERVIEW ---")
    patient_joe.log_vitals(systolic_bp=120, diastolic_bp=80, heart_rate=72, oxygen_sat=98.5)
    current_status = epms.evaluate_clinical_risks(patient_joe.patient_id)
    print(f"Active Diagnostic Alerts: {current_status}\n")
    
    # 5. Scenario B: Logging a sudden decompensation event (emergency anomaly)
    print("--- SIMULATION 2: ACUTE TRAUMA/DECOMPENSATION EVENT ---")
    patient_joe.log_vitals(systolic_bp=85, diastolic_bp=50, heart_rate=118, oxygen_sat=89.0)
    current_status = epms.evaluate_clinical_risks(patient_joe.patient_id)
    
    print(f"!!! CRITICAL ALARM HIGHLIGHT !!!")
    for alert in current_status:
        print(f" -> System Trigger: {alert}")
